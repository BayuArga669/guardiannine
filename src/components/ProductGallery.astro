  {
    id: 1,
    name: "Guardian Core",
    image: "/images/330652174_563990102413749_7981478488627663483_n.jfif",
    tag: "Teratas"
  },
  {
    id: 2,
    name: "Guardian Prime",
    image: "/images/621406986_18102449044836150_6465205560601695048_n.webp", 
    tag: "Populer"
  },
  {
    id: 3,
    name: "Guardian Elite",
    image: "/images/621512559_18067084691212077_1924178572550143224_n.webp",
    tag: "Terbaru"
  },
  {
    id: 4,
